NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Used for absolute scheduling links in emails / clipboard (set on Vercel to your canonical URL, e.g. https://recruitai.example.com)
# NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# AI for resume parsing: Groq (free, 30 RPM) is tried first if GROQ_API_KEY is set; else Gemini.
# Get Groq key (free): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your-gemini-api-key
# Optional: Gemini model (fallback when Groq not used). If unset: gemini-2.5-flash, then gemini-2.0-flash, then gemini-pro.
# GEMINI_MODEL=gemini-2.5-flash

STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Supabase Postgres: same project as NEXT_PUBLIC_SUPABASE_URL.
# Prefer Transaction pooler (port 6543) — direct db.*.supabase.co:5432 often times out from home/VPN/Vercel.
# If your password contains @, #, or special chars, URL-encode them (e.g. @ → %40).
# Pooler (recommended): Supabase → Settings → Database → Connection string → Transaction pooler
#   postgresql://postgres.[PROJECT_REF]:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Direct (can fail with CONNECT_TIMEOUT): postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:xxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Optional: seconds (default 45) if you still see CONNECT_TIMEOUT on slow networks
# DATABASE_CONNECT_TIMEOUT_SEC=90

# Feature flags (default off). HRIS / hired webhooks are controlled in Dashboard → Settings, not by env.
FEATURE_CANDIDATE_EMAIL_AUTOMATION=false
# Interview scheduling (Cal.com) UI: when unset, scheduling settings are shown. Set to false to hide.
# FEATURE_SCHEDULING=false

# Optional SMTP env fallback (used when SMTP config is not set in Dashboard Settings)
# Set SMTP_ENABLED=true to activate this fallback path.
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_FROM_NAME=RecruitAI
