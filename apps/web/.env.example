NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# AI for resume parsing: Groq (free, 30 RPM) is tried first if GROQ_API_KEY is set; else Gemini.
# Get Groq key (free): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your-gemini-api-key
# Optional: Gemini model (fallback when Groq not used). If unset: gemini-2.5-flash, then gemini-2.0-flash, then gemini-pro.
# GEMINI_MODEL=gemini-2.5-flash

STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Supabase: use the same project ref as NEXT_PUBLIC_SUPABASE_URL (e.g. xxx.supabase.co → db.xxx.supabase.co).
# If your password contains @, #, or other special chars, URL-encode them (e.g. @ → %40).
# Direct: postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Pooler (optional): postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:xxx@db.your-project-ref.supabase.co:5432/postgres
